# Copy this to .env and fill in your values
# Never commit .env to git

ANTHROPIC_API_KEY=sk-ant-...
RESEND_API_KEY=re_...

# Must be a verified domain in your Resend dashboard
FROM_EMAIL=digest@yourdomain.com

# Comma-separated, no spaces around commas
TO_EMAILS=you@example.com,friend@example.com

# Optional: override default topics
TOPICS=LLMs, AI agents, ML research, AI policy, open-source AI
